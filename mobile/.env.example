# Lokálny vývoj s Android emulátorom (10.0.2.2 = localhost počítača)
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Produkcia (Vercel)
# EXPO_PUBLIC_API_URL=https://sdkweb.vercel.app

# Google OAuth (voliteľné — ak nie je nastavené, Google tlačidlo sa nezobrazí)
# Získaj z Google Cloud Console → OAuth 2.0 → Android client
# Registruj package: com.swingdancekosice.app + SHA-1 debug keystore
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=
# Web client ID (pre overenie tokenu na backende)
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=
