generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id        String   @id
  title     String
  content   String
  author    String
  createdAt DateTime @default(now())
  status    String   @default("draft")

  @@map("articles")
}
