generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id        String   @id
  title     String
  content   String
  author    String
  createdAt DateTime @default(now())
  status    String   @default("draft")

  @@map("articles")
}

model InternalEvent {
  id        String   @id
  title     String
  start     DateTime
  end       DateTime?
  location  String?
  source    String   @default("internal")
  createdAt DateTime @default(now())

  @@map("internal_events")
}

model InternalMedia {
  id        String   @id
  imageUrl  String
  caption   String?
  source    String   @default("internal")
  createdAt DateTime @default(now())

  @@map("internal_media")
}
