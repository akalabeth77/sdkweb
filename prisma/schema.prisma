generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Article {
  id        String   @id
  title     String
  content   String
  author    String
  createdAt DateTime @default(now())
  status    String   @default("draft")

  @@map("articles")
}

model InternalEvent {
  id        String   @id
  title     String
  description String?
  category  String?  @default("other")
  start     DateTime
  end       DateTime?
  location  String?
  source    String   @default("internal")
  recurrenceGroupId String?
  createdAt DateTime @default(now())

  @@map("internal_events")
}

model InternalMedia {
  id        String   @id
  imageUrl  String
  caption   String?
  source    String   @default("internal")
  createdAt DateTime @default(now())

  @@map("internal_media")
}

model AppUser {
  id           String   @id
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("member")
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  approvedAt   DateTime?

  @@map("app_users")
}

model GalleryAlbum {
  id         String   @id
  title      String
  sourceType String
  sourceRef  String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("gallery_albums")
}
